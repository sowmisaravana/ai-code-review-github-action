# GitHub Credentials
# Generate a Personal Access Token (PAT) with 'repo' and 'pull-requests' access for local testing
GITHUB_TOKEN=your_github_pat_here

# Google Gemini API Key
# Get a key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Configuration for local testing / dry-runs
# Format: owner/repository (e.g. octocat/Hello-World)
GITHUB_REPOSITORY=owner/repo

# Pull Request number to review locally
GITHUB_PR_NUMBER=1

# Gemini Model to use (e.g. gemini-1.5-flash, gemini-1.5-pro, gemini-2.5-flash)
GEMINI_MODEL=gemini-1.5-flash
